import java.util.Scanner;

public class Main {
    public static void main (String[] args) {
        Scanner no = new Scanner(System.in);

        System.out.print("digistre um palavras e vou mostra as vogal: ");

        String p = no.nextLine();
        int c=0;
        p = p.toLowerCase();

        for (int a = 0; a<p.length(); a++){
            char co = p.charAt(a);
            if ( co=='a'||co =='e'||co=='i'||co=='o'||co=='u'){
                c++;
            }
        }
        System.out.print("o numero de vogais sao "+c);

    }
}

