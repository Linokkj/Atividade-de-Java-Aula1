import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner no = new Scanner(System.in);

        int mat[][] = {
                {1, 2, 3},
                {4, 5, 6},
                {7, 8, 9}
        };

        int soma = 0;

        
        for (int s = 0; s < 3; s++) {
            for (int m = 0; m < 3; m++) {
                soma += mat[s][m];
            }
        }

        
        for (int a = 0; a < 3; a++) {
            for (int b = 0; b < 3; b++) {
                System.out.print(mat[a][b] + " ");
            }
            System.out.println();
        }
        
        System.out.println("Soma: " + soma);
    }
}

